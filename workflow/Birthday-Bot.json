      "notes": "Replace YOUR_EVOLUTION_URL and YOUR_INSTANCE_NAME in the URL above. Uses Header Auth credential: name=apikey, value=<key>"
    },
    {
      "parameters": {
        "jsCode": "// Build admin alert payload\nconst contact = $('Extract AI Message').item.json;\nconst error = $input.first().json?.error || $input.first().json;\n\nconst adminNumbers = ['353XXXXXXXXX', '91XXXXXXXXXX'];\nconst alertText = `🚨 *Birthday Bot Alert*\\n\\nFailed to send birthday message after 3 attempts.\\n\\n*Contact:* ${contact.full_name}\\n*Phone:* ${contact.phone_e164}\\n*Error:* ${JSON.stringify(error).substring(0, 300)}\\n\\n_${new Date().toISOString()}_`;\n\nreturn adminNumbers.map(number => ({\n  json: {\n    adminNumber: number,\n    alertText,\n  },\n}));"
      },
