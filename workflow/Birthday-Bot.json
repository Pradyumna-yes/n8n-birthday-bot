    {
      "parameters": {
        "jsCode": "const dupRows = $input.all();\nconst contact = $('Filter Today\\'s Birthdays').item.json;\n\nconst alreadySent = dupRows.some(r => r.json && r.json.id);\n\nreturn [{\n  json: {\n    ...contact,\n    __alreadySent: alreadySent,\n  },\n  pairedItem: { item: 0 },\n}];"
      },
