    {
      "parameters": {
        "method": "POST",
        "url": "https://api.deepseek.com/chat/completions",
        "sendHeaders": true,
        "specifyHeaders": "json",
        "jsonHeaders": "={{ JSON.stringify({\n\n  \"Authorization\": \"Bearer YOUR_DEEPSEEK_API_KEY\",\n\n  \"Content-Type\": \"application/json\"\n\n}) }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"deepseek-chat\",\n  \"temperature\": 0.9,\n  \"max_tokens\": 300,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a thoughtful friend writing a personal WhatsApp birthday message.\\n\\nRules:\\n- Output ONLY the message text. No preamble, no quotes, no sign-off from you.\\n- Length: 2-4 sentences. Short and sincere beats long and generic.\\n- Match the requested tone and language exactly.\\n- If inside jokes are provided, weave ONE of them in naturally. Don't force it.\\n- Sound like a human texting, not a Hallmark card. No cliches like 'may all your dreams come true'.\\n- Use emojis sparingly (max 2), only if the tone calls for it.\\n- If language is Hinglish, mix Hindi and English naturally. If Irish English, use casual Irish phrasing but don't caricature.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a birthday message for:\\n- Name: {{ $json.full_name }}\\n- Relationship to me: {{ $json.relationship || 'friend' }}\\n- Tone: {{ $json.tone || 'warm and friendly' }}\\n- Language: {{ $json.language || 'English' }}\\n- Inside jokes / shared memories: {{ $json.inside_jokes || '(none)' }}\\n\\nRemember: output ONLY the message, nothing else.\"\n    }\n  ]\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "0583a760-76af-4da8-83f3-e2630a190212",
      "name": "DeepSeek: Generate Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3328,
        80
      ],
      "notes": "Uses Header Auth credential: name=Authorization, value=Bearer <key>"
    },
    {
      "parameters": {
        "jsCode": "const contact = $('Merge Duplicate Check').item.json;\nconst apiResponse = $input.first().json;\n\nlet text = apiResponse?.choices?.[0]?.message?.content?.trim() || '';\ntext = text.replace(/^[\"']|[\"']$/g, '').trim();\n\nif (!text) {\n  throw new Error('DeepSeek returned empty message');\n}\n\nreturn [{\n  json: {\n    ...contact,\n    generatedMessage: text,\n  },\n  pairedItem: { item: 0 },\n}];"
      },
