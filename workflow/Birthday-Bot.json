            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "no-birthdays-check",
              "leftValue": "={{ $json.__no_birthdays }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "9efd2cf7-340f-492a-8c5f-fdfc29cec1ae",
      "name": "Any Birthdays Today?",
      "type": "n8n-nodes-base.if",
