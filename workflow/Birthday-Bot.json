    {
      "parameters": {
        "jsCode": "// TEMPORARY: hardcoded to IN for testing. Revert after test.\nconst country = 'IN';\n\nconst tz = country === 'IN' ? 'Asia/Kolkata' : 'Europe/Dublin';\nconst now = new Date();\nconst localDateStr = new Intl.DateTimeFormat('en-CA', {\n  timeZone: tz,\n  year: 'numeric',\n  month: '2-digit',\n  day: '2-digit',\n}).format(now);\n\nconst [yearStr, monthStr, dayStr] = localDateStr.split('-');\nconst year = parseInt(yearStr);\nconst month = parseInt(monthStr);\nconst day = parseInt(dayStr);\nconst monthDay = `${monthStr}-${dayStr}`;\n\nconst isLeapYear = (year % 4 === 0 && year % 100 !== 0) || year % 400 === 0;\nconst includesFeb29 = month === 3 && day === 1 && !isLeapYear;\n\nreturn [{\n  json: {\n    country,\n    timezone: tz,\n    today: localDateStr,\n    monthDay,\n    includesFeb29,\n  },\n}];"
      },
      "id": "3bbe4271-65b8-484a-9763-5ddbd33871ac",
      "name": "Determine Batch + Date",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1168,
        80
      ]
    },
    {
      "parameters": {
        "jsCode": "const batchInfo = $('Determine Batch + Date').first().json;\nconst items = $input.all();\n\nconst [targetMonth, targetDay] = batchInfo.monthDay.split('-').map(Number);\n\nconst matches = [];\nitems.forEach((item, index) => {\n  const c = item.json;\n  if (!c.birthday) return;\n  \n  const [_, m, d] = c.birthday.split('-').map(Number);\n  const isBirthdayToday = (m === targetMonth && d === targetDay);\n  const isFeb29Fallback = (batchInfo.includesFeb29 && m === 2 && d === 29);\n  \n  if (isBirthdayToday || isFeb29Fallback) {\n    matches.push({\n      json: {\n        ...c,\n        today: batchInfo.today,\n        monthDay: batchInfo.monthDay,\n        batchInfo,\n      },\n      pairedItem: { item: index },  // ← THIS is what was missing\n    });\n  }\n});\n\nif (matches.length === 0) {\n  return [{\n    json: { __no_birthdays: true, batchInfo },\n    pairedItem: { item: 0 },\n  }];\n}\n\nreturn matches;"
      },
      "id": "591ad87a-8dcf-4619-b652-d9e664b8e1c1",
      "name": "Filter Today's Birthdays",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
